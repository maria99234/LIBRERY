# Puerto donde corre tu servidor de Node.js
PORT=3000

# Datos de conexión a tu base de datos (PostgreSQL/Supabase)
DB_USER=postgres
DB_PASSWORD=Escribe_Aqui_Tu_Password_De_Supabase
DB_HOST=Escribe_Aqui_La_IP_Actual_O_Host_De_Supabase
DB_PORT=5432
DB_NAME=postgres

# Si usas el string de conexión completo que te da Supabase (opcional):
# DATABASE_URL=postgres://postgres:[password]@[host]:5432/postgres